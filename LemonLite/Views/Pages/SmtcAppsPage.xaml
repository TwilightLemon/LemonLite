<Page x:Class="LemonLite.Views.Pages.SmtcAppsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:base="clr-namespace:LemonLite.Utils"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:LemonLite.Views.Pages"
      xmlns:loc="clr-namespace:LemonLite.Services"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:ws="https://schemas.elecho.dev/wpfsuite"
      Title="SmtcAppsPage"
      d:DataContext="{d:DesignInstance local:SmtcAppsPage}"
      d:DesignHeight="700"
      d:DesignWidth="800"
      Foreground="{DynamicResource ForeColor}"
      mc:Ignorable="d">

    <base:ScrollViewer Padding="12,0" Style="{DynamicResource SimpleVerticalScrollViewerStyle}">
        <ws:StackPanel Spacing="8">
            <TextBlock Margin="0,8"
                       FontSize="22"
                       Text="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[SMTC Apps], Mode=OneWay}" />
            <TextBlock Margin="0,0,0,4"
                       Foreground="{DynamicResource HintForeColor}"
                       Text="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[Configure which apps are monitored. Click an app to configure its sources and aliases.], Mode=OneWay}" />

            <Border Background="{DynamicResource MaskColor}" CornerRadius="12">
                <ws:StackPanel Margin="12" Spacing="8">
                    <Grid>
                        <TextBlock HorizontalAlignment="Left"
                                   VerticalAlignment="Center"
                                   Margin="4 0 0 0"
                                   Text="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[Whitelist], Mode=OneWay}" />
                        <ws:StackPanel Margin="0,0,6,0"
                                       HorizontalAlignment="Right"
                                       Orientation="Horizontal"
                                       Spacing="10">
                            <ws:Button Height="32"
                                       Padding="8"
                                       Command="{Binding AddCurrentAppCommand}"
                                       Style="{StaticResource AccentButtonStyleForWs}">
                                <ws:StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="4">
                                    <TextBlock FontFamily="{StaticResource SegoeFluentIcon}" Text="&#xe710;" />
                                    <TextBlock Text="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[Add Current], Mode=OneWay}" />
                                </ws:StackPanel>
                            </ws:Button>
                            <ws:Button Height="32"
                                       Padding="8"
                                       Command="{Binding AddAppCommand}"
                                       Style="{StaticResource SimpleButtonStyleForWs}">
                                <ws:StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="4">
                                    <TextBlock FontFamily="{StaticResource SegoeFluentIcon}" Text="&#xec50;" />
                                    <TextBlock Text="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[Select File], Mode=OneWay}" />
                                </ws:StackPanel>
                            </ws:Button>
                        </ws:StackPanel>
                    </Grid>

                    <ItemsControl ItemsSource="{Binding SmtcApps}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type local:SmtcAppItemViewModel}">
                                <Border x:Name="AppItemRoot"
                                        Margin="0,4"
                                        Padding="10,12"
                                        Background="{DynamicResource MaskColor}"
                                        CornerRadius="8">
                                    <Grid>
                                        <TextBlock HorizontalAlignment="Left"
                                                   VerticalAlignment="Center"
                                                   FontSize="18"
                                                   Text="{Binding AppId}" />
                                        <ws:StackPanel HorizontalAlignment="Right"
                                                       VerticalAlignment="Center"
                                                       Orientation="Horizontal"
                                                       Spacing="4">
                                            <ws:Button x:Name="DeleteButton"
                                                       Padding="6"
                                                       Command="{Binding DataContext.RemoveAppCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                       CommandParameter="{Binding}"
                                                       Content="&#xf78a;"
                                                       FontFamily="{StaticResource SegoeFluentIcon}"
                                                       FontSize="11"
                                                       Opacity="0"
                                                       Style="{DynamicResource SimpleIconButtonStyleForWs}" />
                                            <ws:Button Padding="6"
                                                       Command="{Binding DataContext.OpenAppCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                       CommandParameter="{Binding}"
                                                       Content="&#xe76c;"
                                                       FontFamily="{StaticResource SegoeFluentIcon}"
                                                       FontSize="14"
                                                       Style="{DynamicResource SimpleIconButtonStyleForWs}" />
                                        </ws:StackPanel>
                                    </Grid>
                                    <Border.Triggers>
                                        <EventTrigger RoutedEvent="MouseEnter">
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetName="DeleteButton"
                                                                     Storyboard.TargetProperty="Opacity"
                                                                     To="1"
                                                                     Duration="0:0:0.2" />
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </EventTrigger>
                                        <EventTrigger RoutedEvent="MouseLeave">
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetName="DeleteButton"
                                                                     Storyboard.TargetProperty="Opacity"
                                                                     To="0"
                                                                     Duration="0:0:0.2" />
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </EventTrigger>
                                    </Border.Triggers>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ws:StackPanel>
            </Border>
        </ws:StackPanel>
    </base:ScrollViewer>
</Page>

<Page x:Class="LemonLite.Views.Pages.SmtcAppDetailPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:base="clr-namespace:LemonLite.Utils"
      xmlns:configs="clr-namespace:LemonLite.Configs"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:LemonLite.Views.Pages"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:ws="https://schemas.elecho.dev/wpfsuite"
      Title="SmtcAppDetailPage"
      d:DataContext="{d:DesignInstance local:SmtcAppDetailPage}"
      d:DesignHeight="700"
      d:DesignWidth="800"
      Foreground="{DynamicResource ForeColor}"
      mc:Ignorable="d">

    <base:ScrollViewer Padding="12,0" Style="{DynamicResource SimpleVerticalScrollViewerStyle}">
        <ws:StackPanel DataContext="{Binding App}" Spacing="8">
            <!--  Header with back button  -->
            <ws:StackPanel Margin="0,8,0,0"
                           Orientation="Horizontal"
                           Spacing="8">
                <ws:Button Padding="6"
                           WindowChrome.IsHitTestVisibleInChrome="True"
                           VerticalAlignment="Center"
                           Command="{Binding DataContext.GoBackCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                           Content="&#xe76b;"
                           FontFamily="{StaticResource SegoeFluentIcon}"
                           FontSize="16"
                           Style="{DynamicResource SimpleIconButtonStyleForWs}" />
                <TextBlock VerticalAlignment="Center"
                           FontSize="22"
                           Text="{Binding AppId}" />
            </ws:StackPanel>

            <!--  Sources Section  -->
            <Border Background="{DynamicResource MaskColor}" CornerRadius="12">
                <ws:StackPanel Margin="12" Spacing="8">
                    <TextBlock FontWeight="Bold" Text="Sources" />

                    <ItemsControl ItemsSource="{Binding Sources}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type local:SmtcSourceEntryViewModel}">
                                <Grid Margin="0,1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               Margin="4,0,8,0"
                                               VerticalAlignment="Center"
                                               Foreground="{DynamicResource HintForeColor}"
                                               Text="{Binding DisplayName}" />
                                    <ws:StackPanel Grid.Column="2"
                                                   Orientation="Horizontal"
                                                   Spacing="2">
                                        <ws:Button Width="26"
                                                   Height="26"
                                                   Padding="4"
                                                   Command="{Binding MoveUpCommand}"
                                                   Content="&#xe74a;"
                                                   FontFamily="{StaticResource SegoeFluentIcon}"
                                                   FontSize="11"
                                                   Style="{DynamicResource SimpleIconButtonStyleForWs}"
                                                   ToolTip="Move Up" />
                                        <ws:Button Width="26"
                                                   Height="26"
                                                   Padding="4"
                                                   Command="{Binding MoveDownCommand}"
                                                   Content="&#xe74b;"
                                                   FontFamily="{StaticResource SegoeFluentIcon}"
                                                   FontSize="11"
                                                   Style="{DynamicResource SimpleIconButtonStyleForWs}"
                                                   ToolTip="Move Down" />
                                        <ws:Button Width="26"
                                                   Height="26"
                                                   Padding="4"
                                                   Command="{Binding RemoveCommand}"
                                                   Content="&#xf78a;"
                                                   FontFamily="{StaticResource SegoeFluentIcon}"
                                                   FontSize="11"
                                                   Style="{DynamicResource SimpleIconButtonStyleForWs}"
                                                   ToolTip="Remove" />
                                    </ws:StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!--  Inactive sources — click to add  -->
                    <ItemsControl ItemsSource="{Binding InactiveSources}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <ws:StackPanel Orientation="Horizontal" Spacing="4" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <ws:Button Padding="12,8"
                                           Command="{Binding DataContext.AddSourceCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                           CommandParameter="{Binding Id}"
                                           Style="{StaticResource SimpleButtonStyleForWs}">
                                    <TextBlock>
                                        <Run BaselineAlignment="Center"
                                             FontFamily="{StaticResource SegoeFluentIcon}"
                                             Text="&#xe710;" />
                                        <Run Text=" " /><Run Text="{Binding DisplayName, Mode=OneWay}" />
                                    </TextBlock>
                                </ws:Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ws:StackPanel>
            </Border>

            <!--  Metadata Alias Section  -->
            <Border Background="{DynamicResource MaskColor}" CornerRadius="12">
                <ws:StackPanel Margin="12" Spacing="8">
                    <Grid>
                        <TextBlock HorizontalAlignment="Left"
                                   VerticalAlignment="Center"
                                   FontWeight="Bold"
                                   Text="Metadata Alias" />
                        <ws:Button Height="32"
                                   Padding="8"
                                   HorizontalAlignment="Right"
                                   Command="{Binding AddAliasCommand}"
                                   Style="{StaticResource AccentButtonStyleForWs}">
                            <TextBlock>
                                <Run BaselineAlignment="Center"
                                     FontFamily="{StaticResource SegoeFluentIcon}"
                                     Text="&#xe710;" />
                                <Run BaselineAlignment="Center" Text=" Add Alias" />
                            </TextBlock>
                        </ws:Button>
                    </Grid>

                    <!--  Column headers  -->
                    <Grid Margin="0,2,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Margin="4,0"
                                   Foreground="{DynamicResource HintForeColor}"
                                   Text="Field" />
                        <TextBlock Grid.Column="1"
                                   Margin="4,0"
                                   Foreground="{DynamicResource HintForeColor}"
                                   Text="Target" />
                        <TextBlock Grid.Column="2"
                                   Margin="4,0"
                                   Foreground="{DynamicResource HintForeColor}"
                                   Text="Alias" />
                    </Grid>

                    <ItemsControl ItemsSource="{Binding Aliases}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type configs:SmtcMetadataAliasItem}">
                                <Grid Margin="0,2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="150" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <ws:ComboBox Height="28"
                                                 Margin="0,0,6,0"
                                                 ItemsSource="{Binding DataContext.AvailableTypes, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                 SelectedItem="{Binding Type, Mode=TwoWay}"
                                                 Style="{StaticResource SimpleComboBoxStyleForWs}" />
                                    <ws:TextBox Grid.Column="1"
                                                Height="28"
                                                Margin="0,0,6,0"
                                                Padding="8,4"
                                                Style="{StaticResource SimpleTextBoxStyleForWs}"
                                                Text="{Binding Target, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    <ws:TextBox Grid.Column="2"
                                                Height="28"
                                                Margin="0,0,6,0"
                                                Padding="8,4"
                                                Style="{StaticResource SimpleTextBoxStyleForWs}"
                                                Text="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    <ws:Button Grid.Column="3"
                                               Width="26"
                                               Height="26"
                                               Padding="4"
                                               Command="{Binding DataContext.RemoveAliasCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                               CommandParameter="{Binding}"
                                               Content="&#xf78a;"
                                               FontFamily="{StaticResource SegoeFluentIcon}"
                                               FontSize="11"
                                               Style="{DynamicResource SimpleIconButtonStyleForWs}"
                                               ToolTip="Remove" />
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ws:StackPanel>
            </Border>

            <!--  Available Sources reference  -->
            <Border Background="{DynamicResource MaskColor}" CornerRadius="12">
                <ws:StackPanel Margin="12,10" Spacing="6">
                    <TextBlock Text="Available Sources" />
                    <ItemsControl ItemsSource="{Binding DataContext.AvailableSources, RelativeSource={RelativeSource AncestorType=Page}}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <ws:StackPanel Orientation="Horizontal" Spacing="8" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="8,4"
                                        Background="{DynamicResource TabMaskColor}"
                                        CornerRadius="6">
                                    <TextBlock Foreground="{DynamicResource HintForeColor}"
                                               Text="{Binding DisplayName}" />
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ws:StackPanel>
            </Border>
        </ws:StackPanel>
    </base:ScrollViewer>
</Page>

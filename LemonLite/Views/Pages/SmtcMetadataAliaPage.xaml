<Page x:Class="LemonLite.Views.Pages.SmtcMetadataAliaPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:base="clr-namespace:LemonLite.Utils"
      xmlns:configs="clr-namespace:LemonLite.Configs"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:LemonLite.Views.Pages"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:ws="https://schemas.elecho.dev/wpfsuite"
      Title="SmtcMetadataAliaPage"
      d:DataContext="{d:DesignInstance local:SmtcMetadataAliaPage}"
      d:DesignHeight="700"
      d:DesignWidth="800"
      Foreground="{DynamicResource ForeColor}"
      mc:Ignorable="d">

    <base:ScrollViewer Padding="12,0" Style="{DynamicResource SimpleVerticalScrollViewerStyle}">
        <ws:StackPanel Spacing="8">
            <TextBlock Margin="0,8"
                       FontSize="22"
                       Text="SMTC Metadata Alias" />
            <TextBlock Margin="0,0,0,4"
                       Foreground="{DynamicResource HintForeColor}"
                       Text="Configure per-app alias replacements for SMTC metadata fields." />

            <ItemsControl ItemsSource="{Binding Apps}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type local:SmtcMetadataAliaAppViewModel}">
                        <Border Margin="0,2"
                                Background="{DynamicResource MaskColor}"
                                CornerRadius="12">
                            <ws:StackPanel Margin="12" Spacing="8">
                                <Grid>
                                    <TextBlock HorizontalAlignment="Left"
                                               VerticalAlignment="Center"
                                               FontWeight="Bold"
                                               FontSize="18"
                                               Text="{Binding AppId}" />
                                    <ws:Button Height="32"
                                               Padding="8"
                                               HorizontalAlignment="Right"
                                               Command="{Binding AddAliasCommand}"
                                               Style="{StaticResource AccentButtonStyleForWs}">
                                        <TextBlock>
                                            <Run BaselineAlignment="Center"
                                                 FontFamily="{StaticResource SegoeFluentIcon}"
                                                 Text="&#xe710;" />
                                            <Run BaselineAlignment="Center" Text=" Add Alias" />
                                        </TextBlock>
                                    </ws:Button>
                                </Grid>

                                <Grid Margin="0,2,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="150" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Margin="4,0"
                                               Foreground="{DynamicResource HintForeColor}"
                                               Text="Field" />
                                    <TextBlock Grid.Column="1"
                                               Margin="4,0"
                                               Foreground="{DynamicResource HintForeColor}"
                                               Text="Target" />
                                    <TextBlock Grid.Column="2"
                                               Margin="4,0"
                                               Foreground="{DynamicResource HintForeColor}"
                                               Text="Alias" />
                                </Grid>

                                <ItemsControl ItemsSource="{Binding Aliases}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="{x:Type configs:SmtcMetadataAliaItem}">
                                            <Grid Margin="0,2">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="150" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <ws:ComboBox Height="28"
                                                            Margin="0,0,6,0"
                                                            ItemsSource="{Binding DataContext.AvailableTypes, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                            SelectedItem="{Binding Type, Mode=TwoWay}"
                                                            Style="{StaticResource SimpleComboBoxStyleForWs}" />
                                                <ws:TextBox Grid.Column="1"
                                                            Height="28"
                                                            Margin="0,0,6,0"
                                                            Padding="8,2"
                                                            Style="{StaticResource SimpleTextBoxStyleForWs}"
                                                            Text="{Binding Target, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                <ws:TextBox Grid.Column="2"
                                                            Height="28"
                                                            Margin="0,0,6,0"
                                                            Padding="8,2"
                                                            Style="{StaticResource SimpleTextBoxStyleForWs}"
                                                            Text="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                <ws:Button Grid.Column="3"
                                                           Width="26"
                                                           Height="26"
                                                           Padding="4"
                                                           Command="{Binding DataContext.RemoveAliasCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                           CommandParameter="{Binding}"
                                                           Content="&#xf78a;"
                                                           FontFamily="{StaticResource SegoeFluentIcon}"
                                                           FontSize="11"
                                                           Style="{DynamicResource SimpleIconButtonStyleForWs}"
                                                           ToolTip="Remove" />
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ws:StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ws:StackPanel>
    </base:ScrollViewer>
</Page>

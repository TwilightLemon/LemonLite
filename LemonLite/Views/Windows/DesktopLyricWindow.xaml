<Window x:Class="LemonLite.Views.Windows.DesktopLyricWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:behavior="clr-namespace:LemonLite.Behaviors"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
        xmlns:loc="clr-namespace:LemonLite.Services"
        xmlns:local="clr-namespace:LemonLite.Views.Windows"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ut="clr-namespace:LemonLite.Utils"
        xmlns:vm="clr-namespace:LemonLite.ViewModels"
        xmlns:ws="https://schemas.elecho.dev/wpfsuite"
        x:Name="window"
        Title="DesktopLyricWindow"
        Width="720"
        Height="145"
        MinHeight="32"
        d:DataContext="{d:DesignInstance Type=vm:DesktopLyricWindowViewModel}"
        AllowsTransparency="True"
        Background="{x:Null}"
        FontFamily="{StaticResource DefaultFontFamily}"
        Foreground="{DynamicResource ForeColor}"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        WindowStyle="None"
        mc:Ignorable="d">
    <i:Interaction.Behaviors>
        <behavior:WindowDragMoveBehavior />
    </i:Interaction.Behaviors>
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0" GlassFrameThickness="-1" />
    </WindowChrome.WindowChrome>
    <Window.Resources>
        <ws:BindingProxy x:Key="proxy" Data="{Binding}" />
    </Window.Resources>
    <Window.ContextMenu>
        <ContextMenu>
            <MenuItem Command="{Binding Data.FontSizeUpCommand, Source={StaticResource proxy}}"
                      Header="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[FontSizeUp], Mode=OneWay}"
                      Icon="{x:Null}" />
            <MenuItem Command="{Binding Data.FontSizeDownCommand, Source={StaticResource proxy}}"
                      Header="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[FontSizeDown], Mode=OneWay}"
                      Icon="{x:Null}" />
        </ContextMenu>
    </Window.ContextMenu>
    <ws:BoxPanel x:Name="windowRoot" Background="#01000000">
        <ut:TopCutBorder x:Name="IsLandBaseBackground"
                         Background="{DynamicResource IslandBackgroundColor}"
                         CornerRadius="24"
                         TopCutRadius="8"
                         Visibility="Collapsed" />
        <ut:TopCutBorder x:Name="AnimatedBackgroundBd"
                         CornerRadius="12"
                         Visibility="{Binding BackgroundVisibility}">
            <ut:TopCutBorder.Background>
                <ImageBrush ImageSource="{Binding BackgroundImageSource, Mode=OneWay}" Stretch="UniformToFill">
                    <ImageBrush.RelativeTransform>
                        <TransformGroup>
                            <TranslateTransform Y="0.5" />
                            <ScaleTransform CenterX="0.5" CenterY="1" ScaleX="2.4" ScaleY="2.4" />
                            <RotateTransform Angle="0" CenterX="0.5" CenterY="1">
                                <i:Interaction.Behaviors>
                                    <behavior:RotateWithPlayingStateBehavior IsEnabled="{Binding IsBackgroundValid}" IsPlaying="{Binding IsPlaying}" />
                                </i:Interaction.Behaviors>
                            </RotateTransform>
                        </TransformGroup>
                    </ImageBrush.RelativeTransform>
                </ImageBrush>
            </ut:TopCutBorder.Background>
            <i:Interaction.Behaviors>
                <behavior:FadeBorderBehavior Source="{Binding BackgroundImageSource}" Duration="00:00:1.5" />
            </i:Interaction.Behaviors>
        </ut:TopCutBorder>
        <Grid x:Name="LrcPanel" IsHitTestVisible="False">
            <ScrollViewer x:Name="LrcScrollViewer"
                          Margin="24,8"
                          HorizontalScrollBarVisibility="Hidden"
                          PanningMode="HorizontalOnly"
                          VerticalScrollBarVisibility="Disabled">
                <ContentControl x:Name="LrcHost"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Content="{Binding LyricControl}" />
            </ScrollViewer>
        </Grid>

        <!--  功能区 鼠标进入后显示  -->
        <Grid x:Name="FuncPanel"
              d:Visibility="Visible"
              Visibility="Collapsed">
            <Border Background="{DynamicResource WindowBackgroundColor}"
                    BorderBrush="{DynamicResource BorderColor}"
                    BorderThickness="1"
                    CornerRadius="12" />
            <ws:WrapPanel HorizontalAlignment="Center"
                          VerticalAlignment="Center"
                          HorizontalSpacing="24">
                <ToggleButton Width="48"
                              Height="48"
                              Padding="12"
                              IsChecked="{Binding ShowTranslation}"
                              Style="{StaticResource IconToggleButton}"
                              Tag="{StaticResource Icon_Trans}"
                              ToolTip="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[ShowTranslationAndRomaji], Mode=OneWay}" />
                <ws:Button x:Name="PlayLastBtn"
                           Width="48"
                           Height="48"
                           HorizontalAlignment="Left"
                           Command="{Binding PlayLastCommand}"
                           Style="{StaticResource SimpleIconButtonStyleForWs}"
                           ToolTip="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[PlayTheLastOne], Mode=OneWay}">
                    <Path Height="22"
                          Data="{DynamicResource PlayIcon_Last}"
                          Fill="{DynamicResource ForeColor}"
                          Stretch="Uniform" />
                </ws:Button>
                <ws:Button x:Name="PlayBtn"
                           Width="54"
                           Height="54"
                           Command="{Binding PlayOrPauseCommand}"
                           Style="{StaticResource SimpleIconButtonStyleForWs}"
                           ToolTip="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[PlayOrPause], Mode=OneWay}">
                    <ws:ConditionalControl Condition="{Binding IsPlaying}">
                        <ws:ConditionalControl.ContentWhenFalse>
                            <Path Data="{DynamicResource PlayIcon_Play}"
                                  Fill="{DynamicResource HighlightThemeColor}"
                                  Stretch="Uniform" />
                        </ws:ConditionalControl.ContentWhenFalse>
                        <ws:ConditionalControl.ContentWhenTrue>
                            <Path Data="{DynamicResource PlayIcon_Pause}"
                                  Fill="{DynamicResource HighlightThemeColor}"
                                  Stretch="Uniform" />
                        </ws:ConditionalControl.ContentWhenTrue>
                    </ws:ConditionalControl>
                </ws:Button>
                <ws:Button x:Name="PlayNextBtn"
                           Width="48"
                           Height="48"
                           HorizontalAlignment="Right"
                           Command="{Binding PlayNextCommand}"
                           Style="{StaticResource SimpleIconButtonStyleForWs}"
                           ToolTip="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[PlayTheNextOne], Mode=OneWay}">
                    <Path Height="22"
                          Data="{DynamicResource PlayIcon_Next}"
                          Fill="{DynamicResource ForeColor}"
                          Stretch="Uniform" />
                </ws:Button>
                <ws:Button Width="48"
                           Height="48"
                           Padding="12"
                           Command="{Binding ShowMainWindowCommand}"
                           Style="{StaticResource SimpleIconButtonStyleForWs}"
                           ToolTip="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[ShowMainWindow], Mode=OneWay}">
                    <Path Height="22"
                          Data="{StaticResource Icon_Show}"
                          Fill="{DynamicResource ForeColor}"
                          Stretch="Uniform" />
                </ws:Button>
            </ws:WrapPanel>
            <ws:Button x:Name="CloseBtn"
                       Width="32"
                       Height="32"
                       Margin="8"
                       HorizontalAlignment="Right"
                       VerticalAlignment="Top"
                       Click="CloseBtn_Click"
                       Content="&#xE8BB;"
                       FontFamily="{StaticResource SegoeFluentIcon}"
                       FontSize="10"
                       Style="{StaticResource SimpleIconButtonStyleForWs}"
                       ToolTip="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[CloseDesktopLyricViewer], Mode=OneWay}" />
        </Grid>
    </ws:BoxPanel>
</Window>

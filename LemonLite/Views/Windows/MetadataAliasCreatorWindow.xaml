<ut:FluentWindowBase x:Class="LemonLite.Views.Windows.MetadataAliasCreatorWindow"
                     xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                     xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                     xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                     xmlns:local="clr-namespace:LemonLite.Views.Windows"
                     xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                     xmlns:ut="clr-namespace:LemonLite.Utils"
                     xmlns:ws="https://schemas.elecho.dev/wpfsuite"
                     Title="Create Metadata Alias"
                     Width="520"
                     Height="280"
                     d:DataContext="{d:DesignInstance local:MetadataAliasCreatorWindow}"
                     Foreground="{DynamicResource ForeColor}"
                     Mode="Acrylic"
                     ResizeMode="CanMinimize"
                     mc:Ignorable="d">
    <ws:StackPanel Margin="16,8,16,16" Spacing="10">
        <!--  AppId  -->
        <ws:StackPanel Orientation="Horizontal" Spacing="8">
            <TextBlock VerticalAlignment="Center"
                       FontWeight="Bold"
                       Text="App:" />
            <TextBlock VerticalAlignment="Center"
                       Foreground="{DynamicResource HintForeColor}"
                       Text="{Binding AppId}" />
            <ws:Button Padding="6"
                       WindowChrome.IsHitTestVisibleInChrome="True"
                       VerticalAlignment="Center"
                       Command="{Binding RefreshCommand}"
                       Content="&#xe72c;"
                       FontFamily="{StaticResource SegoeFluentIcon}"
                       FontSize="12"
                       Style="{DynamicResource SimpleIconButtonStyleForWs}"
                       ToolTip="Refresh" />
        </ws:StackPanel>

        <!--  Fields  -->
        <Border Background="{DynamicResource MaskColor}" CornerRadius="12">
            <ws:StackPanel Margin="12" Spacing="10">
                <!--  Column Headers  -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="60" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="24" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Margin="4,0"
                               Foreground="{DynamicResource HintForeColor}"
                               Text="Field" />
                    <TextBlock Grid.Column="1"
                               Margin="4,0"
                               Foreground="{DynamicResource HintForeColor}"
                               Text="Current" />
                    <TextBlock Grid.Column="3"
                               Margin="4,0"
                               Foreground="{DynamicResource HintForeColor}"
                               Text="Alias" />
                </Grid>

                <!--  Title  -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="60" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="24" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Margin="4,0"
                               VerticalAlignment="Center"
                               Text="Title" />
                    <TextBlock Grid.Column="1"
                               Margin="4,0"
                               VerticalAlignment="Center"
                               Text="{Binding CurrentTitle}"
                               TextTrimming="CharacterEllipsis" />
                    <TextBlock Grid.Column="2"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               FontFamily="{StaticResource SegoeFluentIcon}"
                               FontSize="10"
                               Foreground="{DynamicResource HintForeColor}"
                               Text="&#xe72a;" />
                    <ws:TextBox Grid.Column="3"
                                Height="28"
                                Padding="8,4"
                                Style="{StaticResource SimpleTextBoxStyleForWs}"
                                Text="{Binding NewTitle, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                </Grid>

                <!--  Artist  -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="60" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="24" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Margin="4,0"
                               VerticalAlignment="Center"
                               Text="Artist" />
                    <TextBlock Grid.Column="1"
                               Margin="4,0"
                               VerticalAlignment="Center"
                               Text="{Binding CurrentArtist}"
                               TextTrimming="CharacterEllipsis" />
                    <TextBlock Grid.Column="2"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               FontFamily="{StaticResource SegoeFluentIcon}"
                               FontSize="10"
                               Foreground="{DynamicResource HintForeColor}"
                               Text="&#xe72a;" />
                    <ws:TextBox Grid.Column="3"
                                Height="28"
                                Padding="8,4"
                                Style="{StaticResource SimpleTextBoxStyleForWs}"
                                Text="{Binding NewArtist, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                </Grid>

                <!--  Album  -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="60" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="24" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Margin="4,0"
                               VerticalAlignment="Center"
                               Text="Album" />
                    <TextBlock Grid.Column="1"
                               Margin="4,0"
                               VerticalAlignment="Center"
                               Text="{Binding CurrentAlbum}"
                               TextTrimming="CharacterEllipsis" />
                    <TextBlock Grid.Column="2"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               FontFamily="{StaticResource SegoeFluentIcon}"
                               FontSize="10"
                               Foreground="{DynamicResource HintForeColor}"
                               Text="&#xe72a;" />
                    <ws:TextBox Grid.Column="3"
                                Height="28"
                                Padding="8,4"
                                Style="{StaticResource SimpleTextBoxStyleForWs}"
                                Text="{Binding NewAlbum, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                </Grid>
            </ws:StackPanel>
        </Border>

        <!--  Status and Save  -->
        <Grid>
            <TextBlock HorizontalAlignment="Left"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource HintForeColor}"
                       Text="{Binding StatusText}" />
            <ws:Button Height="32"
                       Padding="16,0"
                       HorizontalAlignment="Right"
                       Command="{Binding SaveCommand}"
                       Style="{StaticResource AccentButtonStyleForWs}">
                <TextBlock>
                    <Run BaselineAlignment="Center"
                         FontFamily="{StaticResource SegoeFluentIcon}"
                         Text="&#xe74e;" />
                    <Run BaselineAlignment="Center" Text=" Save" />
                </TextBlock>
            </ws:Button>
        </Grid>
    </ws:StackPanel>
</ut:FluentWindowBase>
